<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>

    <!-- Start Menu shortcut for the Streamer Dashboard -->
    <Component Id="DashboardStartMenuShortcut" Directory="TarkovMonitorMenuDir">
      <Shortcut
        Id="DashboardMenuShortcut"
        Name="TarkovMonitor Streamer Dashboard"
        Description="TarkovMonitor streaming overlay dashboard"
        Target="[DashboardDir]TarkovMonitor.StreamerDashboard.exe"
        WorkingDirectory="DashboardDir"
        Icon="TarkovMonitorIcon" />
      <RemoveFolder Id="RemoveDashboardMenuDir" Directory="TarkovMonitorMenuDir" On="uninstall" />
      <RegistryValue Root="HKCU"
        Key="SOFTWARE\TarkovMonitor\Dashboard"
        Name="StartMenuShortcut"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>

  </Fragment>

</Wix>

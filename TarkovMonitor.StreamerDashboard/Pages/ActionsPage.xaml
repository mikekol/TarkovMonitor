<Page
    x:Class="TarkovMonitor.StreamerDashboard.Pages.ActionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TarkovMonitor.StreamerDashboard.Pages">

  <Grid Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Event Actions" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,4"/>
    <TextBlock
        Grid.Row="1"
        FontSize="12"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        TextWrapping="Wrap"
        Margin="0,0,0,16">
      Configure a command to run when each event fires.
      Leave Command blank to disable. Arguments support %EVENT% as a placeholder for the event type name.
    </TextBlock>

    <!-- Column headers -->
    <Grid Grid.Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Grid
          Grid.Row="0"
          Padding="8,6"
          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
          CornerRadius="4,4,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="170"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="200"/>
          <ColumnDefinition Width="64"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Event" FontWeight="SemiBold" FontSize="12"/>
        <TextBlock Grid.Column="1" Text="Command (exe / script path)" FontWeight="SemiBold" FontSize="12"/>
        <TextBlock Grid.Column="2" Text="Arguments" FontWeight="SemiBold" FontSize="12"/>
        <TextBlock Grid.Column="3" Text="Test" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center"/>
      </Grid>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="ActionsList">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="local:ActionRowViewModel">
              <Grid
                  Padding="8,5"
                  Margin="0,0,0,2"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  CornerRadius="3">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="170"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="200"/>
                  <ColumnDefinition Width="64"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Text="{x:Bind EventType}"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontFamily="Consolas"/>
                <TextBox
                    Grid.Column="1"
                    Text="{x:Bind CommandLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g. C:\scripts\raid_start.bat"
                    FontSize="12"
                    Margin="4,0"/>
                <TextBox
                    Grid.Column="2"
                    Text="{x:Bind CommandArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="args (optional)"
                    FontSize="12"
                    Margin="4,0"/>
                <Button
                    Grid.Column="3"
                    Content="▶"
                    Tag="{x:Bind}"
                    Click="TestAction_Click"
                    FontSize="11"
                    HorizontalAlignment="Center"
                    ToolTipService.ToolTip="Fire this event type to test the command"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button x:Name="SaveBtn" Content="Save" Style="{ThemeResource AccentButtonStyle}" Click="Save_Click" MinWidth="100"/>
      <TextBlock x:Name="SaveFeedback" VerticalAlignment="Center" FontSize="12"
                 Foreground="{ThemeResource SystemFillColorSuccessBrush}" Visibility="Collapsed"/>
    </StackPanel>
  </Grid>
</Page>
